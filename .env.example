# Copy to .env and fill in. The art pipeline (`weft art --generate`) uses these to
# call an image model; everything else in weft runs with no keys.
#
#   cp .env.example .env

# OpenRouter API key for image generation (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# Optional: override the image model (default: google/gemini-2.5-flash-image).
# OR_IMAGE_MODEL=google/gemini-2.5-flash-image
